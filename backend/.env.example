# Copy to .env and fill in. .env is gitignored.
# Local dev defaults to SQLite — leave DATABASE_URL unset for that.

# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/proready

COURSE_CAPACITY=15
COURSE_CODE=gas-turbine-emissions-mapping-2026-05
COHORT_LABEL=May 15, 2026

# Resend — leave RESEND_API_KEY blank locally to log emails instead of sending.
RESEND_API_KEY=
EMAIL_FROM=ProReadyEngineer <info@proreadyengineer.com>
EMAIL_REPLY_TO=info@proreadyengineer.com
ADMIN_NOTIFY_EMAIL=bmsabry@gmail.com

PAYMENT_INSTRUCTIONS=We'll send a Stripe Payment Link and a PayPal invoice to this email address within 24 hours. Your seat is held as pending until payment clears.
COURSE_PRICE_DISPLAY=

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
